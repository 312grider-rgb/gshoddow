];

let activeCat = 'all';

function getFiltered() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  const typeF = document.getElementById('typeFilter').value;
  const statusF = document.getElementById('statusFilter').value;
  return sessions.filter(s => {
    const catMatch = activeCat === 'all' || s.cat === activeCat;
    const typeMatch = typeF === 'all' || s.type === typeF;
    const statusMatch = statusF === 'all' || s.status === statusF;
    const qMatch = !q || s.title.toLowerCase().includes(q) || s.cat.toLowerCase().includes(q) || s.host.toLowerCase().includes(q);
    return catMatch && typeMatch && statusMatch && qMatch;
  });
}

function cardHTML(s) {
  const liveClass = s.status === 'live' ? 'live-join' : s.status === 'soon' ? 'soon-join' : 'sched-join';
  const liveLabel = s.status === 'live' ? 'Join now' : s.status === 'soon' ? 'Remind me' : 'Reserve spot';
  const statusLabel = s.status === 'live' ? '<span class="status-badge live">Live</span>' :
    s.status === 'soon' ? `<span class="status-badge soon">In ${s.time.replace('In ','')}</span>` :
    `<span class="status-badge scheduled">${s.time}</span>`;
  const typeLabel = `<span class="type-badge ${s.type === 'group' ? 'group' : 'solo'}">${s.type === 'group' ? '👥 Group' : '👤 1-on-1'}</span>`;
  const slotsLeft = s.maxSlots - s.slots;
  return `
    <div class="session-card" onclick="openJoin(${s.id})">
      <div class="card-thumb ${s.thumb}">
        <span>${s.emoji}</span>
        ${statusLabel}
        ${typeLabel}
        <div class="participants-bar">
          <div class="avatars">
            <span>👤</span><span>👤</span><span>👤</span>
          </div>
          <span>${s.slots} joined</span>
        </div>
      </div>
      <div class="card-body">
        <div class="card-cat">${s.cat}</div>
        <div class="card-title">${s.title}</div>
        <div class="card-host">
          <span class="host-avatar">${s.hostInitial}</span>
          ${s.host}
        </div>
        <div class="card-meta">
          <div>
            <div class="card-time">⏱ ${s.duration}</div>
            <div class="card-slots" style="margin-top:3px">🪑 ${slotsLeft > 0 ? slotsLeft + ' spots left' : 'Full'}</div>
          </div>
          <button class="join-btn ${liveClass}" onclick="event.stopPropagation();openJoin(${s.id})">${liveLabel}</button>
        </div>
      </div>
    </div>`;
}

function render() {
  const filtered = getFiltered();
  document.getElementById('liveGrid').innerHTML = filtered.filter(s=>s.status==='live').map(cardHTML).join('') || '<p style="color:var(--muted);font-size:13px;padding:10px 0">No live sessions match your filters.</p>';
  document.getElementById('soonGrid').innerHTML = filtered.filter(s=>s.status==='soon').map(cardHTML).join('') || '<p style="color:var(--muted);font-size:13px;padding:10px 0">None starting soon.</p>';
  document.getElementById('schedGrid').innerHTML = filtered.filter(s=>s.status==='scheduled').map(cardHTML).join('') || '<p style="color:var(--muted);font-size:13px;padding:10px 0">No scheduled sessions.</p>';
}

function filterCards() { render(); }

function selectCat(el, cat) {
  activeCat = cat;
  document.querySelectorAll('.cat-item').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  render();
}

function openJoin(id) {
  const s = sessions.find(x=>x.id===id);
  const liveClass = s.status === 'live' ? 'live-join' : s.status === 'soon' ? 'soon-join' : 'sched-join';
  const liveLabel = s.status === 'live' ? 'Join now →' : s.status === 'soon' ? 'Set reminder' : 'Reserve my spot';
  document.getElementById('joinModalContent').innerHTML = `
    <button class="modal-close" onclick="closeJoin()">✕</button>
    <div class="join-session-emoji">${s.emoji}</div>
    <h2>${s.title}</h2>
    <p style="margin-bottom:0">Hosted by <strong>${s.host}</strong></p>
    <div class="join-meta">
      <div class="join-pill">⏱ ${s.duration}</div>
      <div class="join-pill">${s.type === 'group' ? '👥 Group session' : '👤 1-on-1 session'}</div>
      <div class="join-pill">📅 ${s.time}</div>
      <div class="join-pill">🪑 ${s.maxSlots - s.slots} spots left</div>
    </div>
    <div class="modal-actions" style="margin-top:16px">
      <button class="btn-cancel" onclick="closeJoin()">Back</button>
      <button class="btn-create join-btn ${liveClass}" style="font-family:Syne,sans-serif;font-size:14px;font-weight:700;flex:2;padding:12px;border-radius:10px" onclick="onJoin('${s.title}','${s.status}')">${liveLabel}</button>
    </div>`;
  document.getElementById('joinModal').classList.add('open');
}

function closeJoin() { document.getElementById('joinModal').classList.remove('open'); }
function closeCreate() { document.getElementById('createModal').classList.remove('open'); }
function openCreate() { document.getElementById('createModal').classList.add('open'); }

function onJoin(title, status) {
  closeJoin();
  const msg = status === 'live' ? `Joining "${title}"…` : status === 'soon' ? `Reminder set for "${title}"!` : `Spot reserved for "${title}"!`;
  showToast(msg);
}

function onCreateSession() {
  closeCreate();
  showToast('Your session is live! 🎉');
}

function selectType(btn, type) {
  document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  document.getElementById('maxSlotsGroup').style.display = type === '1-on-1' ? 'none' : 'block';
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3200);
}

render();
</script>
